            StyleBox["a", "TI"], 
            StyleBox["b", "TI"]}]], "\[LongEqual]", "0"}], TraditionalForm], 
     "errors" -> {}, "input" -> "\\overline{R}_{ab} = 0", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "3a288e38-4dfa-3b4c-aabf-f2199975a0f1"],
 " while also setting the background scalar ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         OverscriptBox["\[Phi]", "_"], "\[LongEqual]", "0"}], 
       TraditionalForm], "errors" -> {}, "input" -> "\\overline{\\phi} = 0", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "f41324e3-4010-114d-ae48-42e7c0bf2098"],
 " to give us the simplified equations of motion used (after setting the \
potential to zero):"
}], "Text",
