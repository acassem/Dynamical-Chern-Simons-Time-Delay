Cell[TextData[{
 "To see if the metric is a solution, we check to make sure that at order ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       SuperscriptBox[
        StyleBox["H", "TI"], "2"], TraditionalForm], "errors" -> {}, "input" -> 
     "H^2", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "1ad663c4-9587-fb47-b6ef-e329f820b191"],
 " the Ricci tensor vanishes, ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox[
          OverscriptBox[
           StyleBox["R", "TI"], "_"], 
          RowBox[{
            StyleBox["a", "TI"], 
            StyleBox["b", "TI"]}]], "\[LongEqual]", "0", "+", 
         StyleBox["O", "TI"], 
         RowBox[{"(", 
           SuperscriptBox[
            StyleBox["H", "TI"], "3"], ")"}]}], TraditionalForm], 
     "errors" -> {}, "input" -> "\\overline{R}_{ab} = 0 + \\mathcal{O}(H^3)", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "4d22e3ae-059f-674d-a37d-a09116b207f7"]
}], "Text",
 CellChangeTimes->{{3.984734640628042*^9, 
  3.984734674839737*^9}},ExpressionUUID->"bc580e44-4f57-3441-ab52-\
a0af94707a5c"],

