Cell[BoxData[{
 RowBox[{
  RowBox[{"\[CapitalGamma]", "[", 
   RowBox[{"\[Mu]_", ",", "\[Alpha]_", ",", "\[Beta]_"}], "]"}], ":=", 
  RowBox[{
   FractionBox["1", "2"], 
   RowBox[{"Sum", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"gImet", "[", 
       RowBox[{"[", 
        RowBox[{"\[Mu]", ",", "\[Lambda]"}], "]"}], "]"}], 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"-", 
         RowBox[{"D", "[", 
          RowBox[{
           RowBox[{"gmet", "[", 
            RowBox[{"[", 
             RowBox[{"\[Alpha]", ",", "\[Beta]"}], "]"}], "]"}], ",", 
           RowBox[{"xv", "[", 
            RowBox[{"[", "\[Lambda]", "]"}], "]"}]}], "]"}]}], "+", 
        RowBox[{"D", "[", 
         RowBox[{
          RowBox[{"gmet", "[", 
           RowBox[{"[", 
            RowBox[{"\[Alpha]", ",", "\[Lambda]"}], "]"}], "]"}], ",", 
          RowBox[{"xv", "[", 
           RowBox[{"[", "\[Beta]", "]"}], "]"}]}], "]"}], "+", 
        RowBox[{"D", "[", 
         RowBox[{
          RowBox[{"gmet", "[", 
           RowBox[{"[", 
            RowBox[{"\[Beta]", ",", "\[Lambda]"}], "]"}], "]"}], ",", 
          RowBox[{"xv", "[", 
           RowBox[{"[", "\[Alpha]", "]"}], "]"}]}], "]"}]}], ")"}]}], ",", 
     RowBox[{"{", 
      RowBox[{"\[Lambda]", ",", "1", ",", "dim"}], "}"}]}], 
    "]"}]}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Riem", "[", 
   RowBox[{"\[Rho]_", ",", "\[Sigma]_", ",", "\[Mu]_", ",", "\[Nu]_"}], "]"}],
   ":=", 
  RowBox[{
   RowBox[{"D", "[", 
    RowBox[{
     RowBox[{"\[CapitalGamma]", "[", 
      RowBox[{"\[Rho]", ",", "\[Sigma]", ",", "\[Nu]"}], "]"}], ",", 
     RowBox[{"xv", "[", 
      RowBox[{"[", "\[Mu]", "]"}], "]"}]}], "]"}], "-", 
   RowBox[{"D", "[", 
    RowBox[{
     RowBox[{"\[CapitalGamma]", "[", 
