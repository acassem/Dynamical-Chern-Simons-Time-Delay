Cell["\<\
For simplicity, we use the Lagrangian taken from here \
https://arxiv.org/pdf/0907.2562 and the conventions within can be changed \
later.\
\>", "Text",
 CellChangeTimes->{{3.983964742032484*^9, 
  3.983964764968191*^9}},ExpressionUUID->"0ac6a363-c059-1444-8a0f-\
1ef256c239b2"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"einsteinhilbert", " ", "=", " ", 
   RowBox[{"kappa", "*", 
    RowBox[{"RicciScalarCD", "[", "]"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"chernsimons", " ", "=", " ", 
   RowBox[{
    FractionBox["alpha", "4"], "*", 
    RowBox[{"Phi", "[", "]"}], "*", 
    RowBox[{"(", 
     RowBox[{
      FractionBox["1", "2"], 
      RowBox[{"epsilonmetric", "[", 
       RowBox[{"c", ",", "d", ",", "e", ",", "f"}], "]"}], 
      RowBox[{"RiemannCD", "[", 
       RowBox[{"a", ",", 
        RowBox[{"-", "b"}], ",", 
        RowBox[{"-", "e"}], ",", 
        RowBox[{"-", "f"}]}], "]"}], 
      RowBox[{"RiemannCD", "[", 
       RowBox[{"b", ",", 
        RowBox[{"-", "a"}], ",", 
        RowBox[{"-", "c"}], ",", 
        RowBox[{"-", "d"}]}], "]"}]}], ")"}]}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"scalaraction", " ", "=", " ", 
   RowBox[{
    FractionBox[
     RowBox[{"-", "beta"}], "2"], "*", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{
       RowBox[{"metric", "[", 
        RowBox[{"a", ",", "b"}], "]"}], 
       RowBox[{
        RowBox[{"CD", "[", 
         RowBox[{"-", "a"}], "]"}], "[", 
        RowBox[{"Phi", "[", "]"}], "]"}], 
       RowBox[{
        RowBox[{"CD", "[", 
         RowBox[{"-", "b"}], "]"}], "[", 
        RowBox[{"Phi", "[", "]"}], "]"}]}], " ", "+", " ", 
      RowBox[{"2", "*", 
       RowBox[{"V", "[", 
        RowBox[{"Phi", "[", "]"}], "]"}]}]}], ")"}]}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{"totalaction", " ", "=", " ", 
  RowBox[{
  "einsteinhilbert", "+", "chernsimons", "+", "scalaraction"}]}]}], "Input",
 CellChangeTimes->{{3.9847299205286217`*^9, 3.984729923652727*^9}},
 CellLabel->"In[18]:=",ExpressionUUID->"a436a968-3081-2f47-9ed7-c5b820567a9f"],

