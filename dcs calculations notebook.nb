Cell["\<\
Change of variables using our coordinate system in the paper, integrate over, \
and then series in the wide Gaussian limit:\
\>", "Text",
 CellChangeTimes->{{3.984735782606447*^9, 
  3.984735822659704*^9}},ExpressionUUID->"be2311a7-7ce4-664d-8aa7-\
c2d99e530a3f"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"Vp2pieceinT", " ", "=", " ", 
   RowBox[{
    RowBox[{"FullSimplify", "[", 
     RowBox[{
      RowBox[{"Vphase2", "/.", 
       RowBox[{"{", 
        RowBox[{"z", "->", 
         RowBox[{"t", "*", 
          RowBox[{"Cos", "[", "\[Theta]", "]"}]}]}], "}"}]}], ",", 
      RowBox[{"Assumptions", "->", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"\[Omega]", ">", "1"}], ",", 
         RowBox[{"MagK", ">", "1"}], ",", 
         RowBox[{"MagK", "\[Element]", "Reals"}], ",", 
         RowBox[{"0", "<", "\[Theta]", "<", 
          RowBox[{"\[Pi]", "/", "2"}]}], ",", 
         RowBox[{"t", "\[Element]", "Reals"}]}], "}"}]}]}], "]"}], "/.", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{
       RowBox[{"kx", "^", "2"}], "+", 
       RowBox[{"ky", "^", "2"}], "+", 
       RowBox[{"kz", "^", "2"}]}], "->", 
      RowBox[{"MagK", "^", "2"}]}], "}"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Vp2pieceDeltaT", " ", "=", " ", 
   RowBox[{
    RowBox[{"Integrate", "[", 
     RowBox[{
      RowBox[{"Vp2pieceinT", "/.", 
       RowBox[{"{", 
        RowBox[{"\[Sigma]", "->", 
         RowBox[{"\[Sigma]", "^", "2"}]}], "}"}]}], ",", 
      RowBox[{"{", 
       RowBox[{"t", ",", 
        RowBox[{"-", "Infinity"}], ",", "Infinity"}], "}"}], ",", 
      RowBox[{"Assumptions", "->", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"\[Omega]", ">", "1"}], ",", 
         RowBox[{"MagK", ">", "1"}], ",", 
         RowBox[{"MagK", "\[Element]", "Reals"}], ",", 
         RowBox[{"0", "<", "\[Theta]", "<", 
          RowBox[{"\[Pi]", "/", "2"}]}], ",", 
         RowBox[{"kx", ">", "1"}], ",", 
         RowBox[{"ky", ">", "1"}], ",", 
         RowBox[{"kz", ">", "1"}], ",", 
         RowBox[{"kz", "\[Element]", "Reals"}], ",", 
         RowBox[{"kx", "\[Element]", "Reals"}], ",", 
         RowBox[{"ky", "\[Element]", "Reals"}]}], "}"}]}]}], "]"}], "//", 
    "Normal"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"Series", "[", 
     RowBox[{"Vp2pieceDeltaT", ",", 
      RowBox[{"{", 
       RowBox[{"\[Sigma]", ",", "Infinity", ",", "1"}], "}"}]}], "]"}], "//", 
    "Normal"}], ";"}], 
  RowBox[{"(*", 
   RowBox[{
   "pull", " ", "off", " ", "the", " ", "most", " ", "divergent", " ", 
    "piece"}], "*)"}]}]}], "Input",
 CellChangeTimes->{{3.9847357666939754`*^9, 3.9847357785505886`*^9}, {
  3.9847358349000854`*^9, 3.9847358442313004`*^9}},
