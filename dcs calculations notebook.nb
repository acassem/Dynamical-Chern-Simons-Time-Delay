          RowBox[{"ky", "[", "y", "]"}], "^", "2"}], "+", 
         RowBox[{
          RowBox[{"kz", "[", "z", "]"}], "^", "2"}]}], "->", 
        RowBox[{"MagK", "^", "2"}]}], "}"}]}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"vt", " ", "=", " ", 
