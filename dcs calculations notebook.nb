Cell[TextData[{
 "Since we can treat ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"\[Omega]", 
         RowBox[{"(", 
           StyleBox["t", "TI"], ")"}], "\[LongEqual]", 
         SqrtBox[
          RowBox[{
            SubsuperscriptBox[
             StyleBox["k", "TI"], "1", "2"], "+", 
            SubsuperscriptBox[
             StyleBox["k", "TI"], "2", "2"], "+", 
            SubsuperscriptBox[
             StyleBox["k", "TI"], "3", "2"]}]]}], TraditionalForm], 
     "errors" -> {}, "input" -> "\\omega(t) = \\sqrt{k_1^2 + k_2^2 + k_3^2}", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "7709802f-1c44-3046-9674-889f7a918954"],
 ", then terms that are of order ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       SuperscriptBox[
        StyleBox["h", "TI"], "2"], TraditionalForm], "errors" -> {}, "input" -> 
     "h^2", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "2f2590f2-87dd-db46-a706-8bb12846df82"],
 " multiplied by ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       SuperscriptBox["\[Omega]", "2"], TraditionalForm], "errors" -> {}, 
     "input" -> "\\omega^2", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "f49321c2-37e3-3f48-ae15-0569ca0842a3"],
 ", will be of the same order as ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       SuperscriptBox[
        StyleBox["h", "TI"], "3"], TraditionalForm], "errors" -> {}, "input" -> 
     "h^3", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "c545e86a-9eb7-7c43-915d-9a638723d72a"],
 ", and thus we can drop them, as seen in the order ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       SuperscriptBox["\[Rho]", "2"], TraditionalForm], "errors" -> {}, 
     "input" -> "\\rho^2", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "b1b08574-524a-ea40-8d26-092d55cb01ee"],
 " term. Hence, we truncate to these terms, namely the highlighted portion I \
display below:"
}], "Text",
 CellChangeTimes->{
  3.9847324412254276`*^9},ExpressionUUID->"fb33fd0b-b7ce-6347-bb8b-\
d26bb758d60a"],

