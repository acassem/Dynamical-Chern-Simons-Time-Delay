Notebook[{
Cell[BoxData[
 RowBox[{
  RowBox[{"Quit", "[", "]"}], ";"}]], "Input",
 CellChangeTimes->{{3.984737017826557*^9, 3.984737019235283*^9}},
 CellLabel->"In[57]:=",ExpressionUUID->"90647f5d-0aee-2043-96e1-93dd6ba76633"],

Cell[TextData[{
 "This notebook is to accompany paper https://arxiv.org/abs/2604.07332",
 StyleBox[" ",
  FontWeight->"Bold",
  FontSlant->"Italic"],
 StyleBox[" ",
  FontSlant->"Italic"],
 "to show the computation of the perturbed equations of motion in section 2, \
the dispersion relation on the background metric in section 3, and then \
showing the second order metric used to compute Shapiro at second order is \
indeed a solution.\n\nThe first part is using xAct and subpackages while the \
second part does not require such packages; the reason for this was purely \
computational speed."
}], "Text",
 CellChangeTimes->{{3.9839577586177206`*^9, 3.983957762448099*^9}, {
  3.983957793400669*^9, 3.983957887745482*^9}, {3.9847298332994175`*^9, 
  3.98472984992556*^9}, {3.984730522949438*^9, 
  3.9847305660342274`*^9}},ExpressionUUID->"beb2139d-115b-7b41-aa82-\
9b262a9db499"],

Cell[CellGroupData[{

Cell["1) Packages, EOMs, Perturbations, and Dispersion Relation", "Section",
 CellChangeTimes->{{3.983964463143795*^9, 3.983964504784083*^9}, {
  3.9847305088398952`*^9, 
  3.9847305145959663`*^9}},ExpressionUUID->"ef9364cb-968f-4340-bb82-\
00dad0250174"],

Cell[CellGroupData[{

Cell["1.1) Packages", "Subsection",
 CellChangeTimes->{{3.9839645139334564`*^9, 
  3.9839645158528767`*^9}},ExpressionUUID->"1e9e2420-f6ea-f74f-8acc-\
1a15751502d5"],

Cell["\<\
We use xAct and packages built within and around the framework. For \
installation and usage please see this website and links therein: \
https://josmar493.dreamhosters.com/\
\>", "Text",
 CellChangeTimes->{{3.983964522745056*^9, 
  3.98396456533516*^9}},ExpressionUUID->"3f74af6d-121f-384f-b15e-\
