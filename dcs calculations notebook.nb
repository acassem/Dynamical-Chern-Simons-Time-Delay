         RowBox[{"\[Sigma]", "^", "2"}]}], "}"}]}], ",", 
      RowBox[{"{", 
       RowBox[{"t", ",", 
        RowBox[{"-", "Infinity"}], ",", "Infinity"}], "}"}], ",", 
      RowBox[{"Assumptions", "->", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"\[Omega]", ">", "1"}], ",", 
         RowBox[{"MagK", ">", "1"}], ",", 
         RowBox[{"MagK", "\[Element]", "Reals"}], ",", 
         RowBox[{"0", "<", "\[Theta]", "<", 
          RowBox[{"\[Pi]", "/", "2"}]}], ",", 
         RowBox[{"kx", ">", "1"}], ",", 
         RowBox[{"ky", ">", "1"}], ",", 
         RowBox[{"kz", ">", "1"}], ",", 
         RowBox[{"kz", "\[Element]", "Reals"}], ",", 
         RowBox[{"kx", "\[Element]", "Reals"}], ",", 
         RowBox[{"ky", "\[Element]", "Reals"}]}], "}"}]}]}], "]"}], "//", 
    "Normal"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Vgroupseries", " ", "=", " ", 
   RowBox[{
    RowBox[{"Normal", "[", 
     RowBox[{"Series", "[", 
      RowBox[{"Vgroup2pieceDeltaT", ",", 
       RowBox[{"{", 
        RowBox[{"\[Sigma]", ",", "Infinity", ",", "1"}], "}"}]}], "]"}], 
     "]"}], "/.", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"kx", "->", 
       RowBox[{"MagK", "*", 
        RowBox[{"Sin", "[", "\[Theta]", "]"}], 
        RowBox[{"Cos", "[", "\[Phi]", "]"}]}]}], ",", 
      RowBox[{"ky", "->", 
       RowBox[{"MagK", "*", 
        RowBox[{"Sin", "[", "\[Theta]", "]"}], "*", 
        RowBox[{"Sin", "[", "\[Phi]", "]"}]}]}], ",", 
      RowBox[{"kz", "->", 
       RowBox[{"MagK", "*", 
        RowBox[{"Cos", "[", "\[Theta]", "]"}]}]}]}], "}"}]}]}], 
  ";"}]}], "Input",
 CellChangeTimes->{{3.9847361397264557`*^9, 3.9847361540631256`*^9}, {
  3.98473629593692*^9, 3.984736297366932*^9}},
 CellLabel->"In[51]:=",ExpressionUUID->"0ded7a32-f908-bc4b-baae-e609ff60d8e1"],

Cell[TextData[{
 "To check the differences in the phase and group velocity (note that the ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|
    "boxes" -> FormBox["\[Phi]", TraditionalForm], "errors" -> {}, "input" -> 
     "\\phi", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "8d599472-4b0e-af48-a92d-762b6296bdcd"],
 " here is really ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|
    "boxes" -> FormBox["\[CurlyPhi]", TraditionalForm], "errors" -> {}, 
     "input" -> "\\varphi", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "67eddd73-4d05-4a43-b898-6986192541e6"],
 " in the paper):"
}], "Text",
 CellChangeTimes->{{3.984736323504608*^9, 
  3.984736348857136*^9}},ExpressionUUID->"407ae6ae-c263-334c-be7c-\
dbc2c6078242"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"Vgroupseries", "-", "Vphaseseries"}], "//", "Simplify"}]], "Input",
 CellLabel->"In[54]:=",ExpressionUUID->"a8ef14e0-ac37-a948-a567-68e808c7eb59"],

Cell[BoxData[
 RowBox[{
  FractionBox["1", "8"], " ", 
  SuperscriptBox["\[ExponentialE]", 
   RowBox[{
    RowBox[{"-", 
     SuperscriptBox["\[Sigma]", "2"]}], " ", 
    SuperscriptBox["\[Omega]", "2"]}]], " ", 
  RowBox[{"(", 
   RowBox[{"1", "+", 
    SuperscriptBox["\[ExponentialE]", 
     RowBox[{
      SuperscriptBox["\[Sigma]", "2"], " ", 
      SuperscriptBox["\[Omega]", "2"]}]]}], ")"}], " ", 
  SuperscriptBox["H", "2"], " ", 
  SqrtBox["\[Pi]"], " ", "\[Sigma]", " ", 
  SuperscriptBox[
   RowBox[{"Cos", "[", 
    FractionBox["\[Theta]", "2"], "]"}], "2"], " ", 
  RowBox[{"(", 
   RowBox[{"6", "+", 
    RowBox[{"2", " ", 
     RowBox[{"Cos", "[", 
      RowBox[{"2", " ", "\[Theta]"}], "]"}]}], "-", 
    RowBox[{"Sin", "[", 
     RowBox[{"2", " ", 
      RowBox[{"(", 
       RowBox[{"\[Theta]", "-", 
        RowBox[{"2", " ", "\[Phi]"}]}], ")"}]}], "]"}], "-", 
    RowBox[{"2", " ", 
     RowBox[{"Sin", "[", 
      RowBox[{"4", " ", "\[Phi]"}], "]"}]}], "+", 
    RowBox[{"Sin", "[", 
     RowBox[{"2", " ", 
      RowBox[{"(", 
       RowBox[{"\[Theta]", "+", 
        RowBox[{"2", " ", "\[Phi]"}]}], ")"}]}], "]"}]}], ")"}]}]], "Output",
 CellChangeTimes->{3.9847363913283577`*^9},
 CellLabel->"Out[54]=",ExpressionUUID->"1a2040d2-1432-794b-8a74-45659e0c63c2"]
}, Closed]],

Cell[TextData[{
 "And so we see they only differ at order ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|
    "boxes" -> FormBox["\[Sigma]", TraditionalForm], "errors" -> {}, "input" -> 
     "\\sigma", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "c0d00d89-b021-9e4f-8e47-644db575d787"],
 " in the wide Gaussian limit but their ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       SuperscriptBox["\[Sigma]", "3"], TraditionalForm], "errors" -> {}, 
     "input" -> "\\sigma^3", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "115778fa-f1c8-c947-8829-c5f3e133248a"],
 " terms are the same:"
}], "Text",
 CellChangeTimes->{{3.984736365826849*^9, 
  3.9847363920616074`*^9}},ExpressionUUID->"646ac7ef-214a-6145-a9c3-\
a3bf74081e3d"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Vgdiv", " ", "=", " ", 
  RowBox[{"Simplify", "[", 
   RowBox[{
    FractionBox[
     RowBox[{"-", "1"}], 
     RowBox[{"16", " ", 
      SuperscriptBox["MagK", "4"], " ", 
      SuperscriptBox[
       RowBox[{"(", 
        RowBox[{"1", "-", 
         RowBox[{"Cos", "[", "\[Theta]", "]"}]}], ")"}], "3"]}]], 
    SuperscriptBox["H", "2"], " ", 
    SqrtBox["\[Pi]"], " ", 
    SuperscriptBox["\[Sigma]", "3"], " ", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{
       RowBox[{"-", "2"}], " ", 
       SuperscriptBox["MagK", "4"], " ", 
       SuperscriptBox["\[Omega]", "2"], " ", 
       SuperscriptBox[
        RowBox[{"Cos", "[", "\[Theta]", "]"}], "4"]}], "-", 
      RowBox[{"4", " ", 
       SuperscriptBox["MagK", "2"], " ", 
       SuperscriptBox["\[Omega]", "2"], " ", 
       RowBox[{"Cos", "[", "\[Theta]", "]"}], " ", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{"2", " ", 
          SuperscriptBox["MagK", "2"], " ", 
          RowBox[{"Cos", "[", "\[Theta]", "]"}]}], "+", 
         RowBox[{
          SuperscriptBox["MagK", "2"], " ", 
          SuperscriptBox[
           RowBox[{"Cos", "[", "\[Phi]", "]"}], "2"], " ", 
          SuperscriptBox[
           RowBox[{"Sin", "[", "\[Theta]", "]"}], "2"]}], "+", 
         RowBox[{
          SuperscriptBox["MagK", "2"], " ", 
          SuperscriptBox[
           RowBox[{"Sin", "[", "\[Theta]", "]"}], "2"], " ", 
          SuperscriptBox[
           RowBox[{"Sin", "[", "\[Phi]", "]"}], "2"]}]}], ")"}]}], "-", 
      RowBox[{"2", " ", 
       SuperscriptBox["MagK", "2"], " ", 
       SuperscriptBox["\[Omega]", "2"], " ", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{"MagK", " ", 
          RowBox[{"Cos", "[", "\[Theta]", "]"}], " ", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{
             RowBox[{"-", "2"}], " ", "MagK"}], "+", 
            RowBox[{"3", " ", "MagK", " ", 
             RowBox[{"Cos", "[", "\[Theta]", "]"}]}]}], ")"}]}], "+", 
         RowBox[{
          SuperscriptBox["MagK", "2"], " ", 
          SuperscriptBox[
           RowBox[{"Cos", "[", "\[Phi]", "]"}], "2"], " ", 
          SuperscriptBox[
           RowBox[{"Sin", "[", "\[Theta]", "]"}], "2"]}], "+", 
         RowBox[{
          SuperscriptBox["MagK", "2"], " ", 
          SuperscriptBox[
           RowBox[{"Sin", "[", "\[Theta]", "]"}], "2"], " ", 
          SuperscriptBox[
           RowBox[{"Sin", "[", "\[Phi]", "]"}], "2"]}]}], ")"}]}]}], ")"}]}], 
   "]"}]}]], "Input",
 CellLabel->"In[56]:=",ExpressionUUID->"39ff6c31-c5c0-834e-8492-5647b1115c6c"],

Cell[BoxData[
 RowBox[{
  FractionBox["1", "512"], " ", 
  SuperscriptBox["H", "2"], " ", 
  SqrtBox["\[Pi]"], " ", 
  SuperscriptBox["\[Sigma]", "3"], " ", 
  SuperscriptBox["\[Omega]", "2"], " ", 
  RowBox[{"(", 
   RowBox[{"35", "-", 
    RowBox[{"12", " ", 
     RowBox[{"Cos", "[", "\[Theta]", "]"}]}], "+", 
    RowBox[{"28", " ", 
     RowBox[{"Cos", "[", 
      RowBox[{"2", " ", "\[Theta]"}], "]"}]}], "-", 
    RowBox[{"4", " ", 
     RowBox[{"Cos", "[", 
      RowBox[{"3", " ", "\[Theta]"}], "]"}]}], "+", 
    RowBox[{"Cos", "[", 
     RowBox[{"4", " ", "\[Theta]"}], "]"}]}], ")"}], " ", 
  SuperscriptBox[
   RowBox[{"Csc", "[", 
    FractionBox["\[Theta]", "2"], "]"}], "6"]}]], "Output",
 CellChangeTimes->{3.9847364295000153`*^9},
 CellLabel->"Out[56]=",ExpressionUUID->"2a860ac9-cae0-214b-99d4-e657d869caa7"]
}, Closed]],

