Cell[TextData[{
 "Our non-linear dispersion relation has on the LHS a ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       SuperscriptBox[
        StyleBox["k", "TI"], "4"], TraditionalForm], "errors" -> {}, "input" -> 
     "k^4", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "c3a9e24e-81a8-5e41-91a1-3b179e898c98"],
 " power that goes as ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SuperscriptBox[
          RowBox[{"(", 
            RowBox[{
              SubscriptBox[
               StyleBox["k", "TI"], 
               StyleBox["a", "TI"]], 
              SubscriptBox[
               StyleBox["k", "TI"], 
               StyleBox["b", "TI"]], 
              SuperscriptBox[
               OverscriptBox[
                StyleBox["g", "TI"], "_"], 
               RowBox[{
                 StyleBox["a", "TI"], 
                 StyleBox["b", "TI"]}]]}], ")"}], "2"], "\[LongEqual]", 
         SubscriptBox[
          StyleBox["k", "TI"], 
          StyleBox["a", "TI"]], 
         SubscriptBox[
          StyleBox["k", "TI"], 
          StyleBox["b", "TI"]], 
         SubscriptBox[
          StyleBox["k", "TI"], 
          StyleBox["c", "TI"]], 
         SubscriptBox[
          StyleBox["k", "TI"], 
          StyleBox["d", "TI"]], 
         SuperscriptBox[
          OverscriptBox[
           StyleBox["g", "TI"], "_"], 
          RowBox[{
            StyleBox["a", "TI"], 
            StyleBox["b", "TI"]}]], 
         SuperscriptBox[
          OverscriptBox[
           StyleBox["g", "TI"], "_"], 
          RowBox[{
            StyleBox["c", "TI"], 
            StyleBox["d", "TI"]}]]}], TraditionalForm], "errors" -> {}, 
     "input" -> 
     "(k_a k_b \\overline{g}^{ab})^2 = k_a k_b k_c k_d \
\\overline{g}^{ab}\\overline{g}^{cd}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "8cb10259-1935-7b49-9adf-452a449f3f04"],
 " where we define the wave vector in the ",
 StyleBox["covariant ",
  FontSlant->"Italic"],
 "manner. However, the RHS is schematically ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"\[Tilde]\[Epsilon]\[Epsilon]", 
         OverscriptBox[
          StyleBox["R", "TI"], "_"], 
         OverscriptBox[
          StyleBox["R", "TI"], "_"], 
         SuperscriptBox[
          StyleBox["k", "TI"], 
          StyleBox["a", "TI"]], 
         SuperscriptBox[
          StyleBox["k", "TI"], 
          StyleBox["b", "TI"]], 
         SuperscriptBox[
          StyleBox["k", "TI"], 
          StyleBox["c", "TI"]], 
         SuperscriptBox[
          StyleBox["k", "TI"], 
          StyleBox["d", "TI"]]}], TraditionalForm], "errors" -> {}, "input" -> 
     "\\sim \\epsilon\\epsilon\\overline{R}\\overline{R} k^a k^b k^c k^d", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "a62c948d-ffaf-1549-a12c-a23522d09839"],
 " where the wave vectors are ",
 StyleBox["contravariant. ",
  FontSlant->"Italic"],
 "Computationally, this means Mathematica will have to perform the sum ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SuperscriptBox[
          StyleBox["k", "TI"], 
          StyleBox["a", "TI"]], "\[LongEqual]", 
         SuperscriptBox[
          OverscriptBox[
           StyleBox["g", "TI"], "_"], 
          RowBox[{
            StyleBox["a", "TI"], 
            StyleBox["b", "TI"]}]], 
         SubscriptBox[
          StyleBox["k", "TI"], 
          StyleBox["b", "TI"]]}], TraditionalForm], "errors" -> {}, "input" -> 
     "k^a = \\overline{g}^{ab}k_b", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "d08c89f4-e47d-b540-826b-207832927974"],
 " for each wave vector! This is computationally a nightmare (unless you have \
the computer time), but luckily we can treat ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SuperscriptBox[
          StyleBox["k", "TI"], 
          StyleBox["a", "TI"]], "\[LongEqual]", 
         RowBox[{"(", 
           RowBox[{
             SuperscriptBox["\[Eta]", 
              RowBox[{
                StyleBox["a", "TI"], 
                StyleBox["b", "TI"]}]], "-", "\[Kappa]", 
             SuperscriptBox[
              OverscriptBox[
               StyleBox["h", "TI"], "_"], 
              RowBox[{
                StyleBox["a", "TI"], 
                StyleBox["b", "TI"]}]]}], ")"}], 
         SubscriptBox[
          StyleBox["k", "TI"], 
          StyleBox["b", "TI"]], "\[TildeTilde]", 
         SuperscriptBox["\[Eta]", 
          RowBox[{
            StyleBox["a", "TI"], 
            StyleBox["b", "TI"]}]], 
         SubscriptBox[
          StyleBox["k", "TI"], 
          StyleBox["b", "TI"]]}], TraditionalForm], "errors" -> {}, "input" -> 
     "k^a = (\\eta^{ab} - \\kappa \\overline{h}^{ab})k_b\\approx \
\\eta^{ab}k_b", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "18df7bf4-17e7-b746-9dc2-3f313b07757f"],
 " since on the RHS we are already dealing with second order in the \
perturbations ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       SubscriptBox[
        StyleBox["h", "TI"], 
        RowBox[{
          StyleBox["a", "TI"], 
          StyleBox["b", "TI"]}]], TraditionalForm], "errors" -> {}, "input" -> 
     "h_{ab}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "2959fc45-d25f-b246-9e32-678b59e8761b"],
 ".  And so, we can relabel the wave vectors on the RHS from ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SuperscriptBox[
          StyleBox["k", "TI"], 
          StyleBox["a", "TI"]], "\[Rule]", 
         SuperscriptBox[
          StyleBox["p", "TI"], 
          StyleBox["a", "TI"]]}], TraditionalForm], "errors" -> {}, "input" -> 
     "k^a\\rightarrow p^a", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "c3f263d7-c06a-df41-8e03-a9febad7d8dd"],
 " where we can define the new contravariant momenta as ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SuperscriptBox[
          StyleBox["p", "TI"], 
          StyleBox["a", "TI"]], "\[LongEqual]", 
         RowBox[{"(", 
           RowBox[{"-", "\[Omega]", ",", 
             SubscriptBox[
              StyleBox["k", "TI"], "1"], ",", 
             SubscriptBox[
              StyleBox["k", "TI"], "2"], ",", 
             SubscriptBox[
              StyleBox["k", "TI"], "3"]}], ")"}]}], TraditionalForm], 
     "errors" -> {}, "input" -> "p^a = (-\\omega,k_1,k_2,k_3)", "state" -> 
     "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "148c2c9e-7c36-3544-a6d1-4f177b5a30f4"],
 ". "
}], "Text",
 CellChangeTimes->{
  3.9847308256415787`*^9},ExpressionUUID->"5f74b62c-0a3a-4245-ae17-\
cfab0c3cc34c"],

