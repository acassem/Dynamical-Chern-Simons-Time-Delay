Cell[BoxData[
 TagBox[
  RowBox[{"(", "\[NoBreak]", GridBox[{
     {
      InterpretationBox[
       RowBox[{
        RowBox[{"-", 
         RowBox[{
          FractionBox["1", "2"], " ", 
          RowBox[{"(", 
           RowBox[{
            SuperscriptBox["\[Omega]", "2"], " ", 
            RowBox[{"(", 
             RowBox[{
              RowBox[{"3", " ", 
               RowBox[{"Cos", "[", 
                RowBox[{
                 RowBox[{"(", 
                  RowBox[{"t", "-", "z"}], ")"}], " ", "\[Omega]"}], "]"}]}], 
              "+", 
              RowBox[{"7", " ", 
               RowBox[{"Cos", "[", 
                RowBox[{"3", " ", 
                 RowBox[{"(", 
                  RowBox[{"t", "-", "z"}], ")"}], " ", "\[Omega]"}], 
                "]"}]}]}], ")"}]}], ")"}], " ", 
          SuperscriptBox["H", "3"]}]}], "+", 
        InterpretationBox[
         SuperscriptBox[
          RowBox[{"O", "[", "H", "]"}], "4"],
         SeriesData[$CellContext`H, 0, {}, 3, 4, 1],
         Editable->False]}],
       SeriesData[$CellContext`H, 0, {
        Rational[-1, 2] $CellContext`\[Omega]^2 (
          3 Cos[($CellContext`t - $CellContext`z) $CellContext`\[Omega]] + 
          7 Cos[3 ($CellContext`t - $CellContext`z) $CellContext`\[Omega]])}, 
        3, 4, 1],
       Editable->False], "0", "0", 
      InterpretationBox[
       RowBox[{
        RowBox[{
         FractionBox["1", "2"], " ", 
         SuperscriptBox["\[Omega]", "2"], " ", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"3", " ", 
            RowBox[{"Cos", "[", 
             RowBox[{
              RowBox[{"(", 
