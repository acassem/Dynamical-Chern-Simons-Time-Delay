Cell[TextData[{
 "Here is the LHS of the dispersion relation i.e. ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SuperscriptBox[
          RowBox[{"(", 
            RowBox[{
              SubscriptBox[
               StyleBox["k", "TI"], 
               StyleBox["a", "TI"]], 
              SuperscriptBox[
               StyleBox["k", "TI"], 
               StyleBox["a", "TI"]]}], ")"}], "2"], "\[LongEqual]", 
         SubscriptBox[
          StyleBox["k", "TI"], 
          StyleBox["a", "TI"]], 
         SuperscriptBox[
          StyleBox["k", "TI"], 
          StyleBox["a", "TI"]], 
         SubscriptBox[
          StyleBox["k", "TI"], 
          StyleBox["b", "TI"]], 
         SuperscriptBox[
          StyleBox["k", "TI"], 
          StyleBox["b", "TI"]]}], TraditionalForm], "errors" -> {}, "input" -> 
