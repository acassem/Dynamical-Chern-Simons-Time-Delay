Cell[CellGroupData[{

Cell["2.1) Brief Preface", "Subsection",
 CellChangeTimes->{{3.9847342783585796`*^9, 
  3.9847342821918564`*^9}},ExpressionUUID->"b04acdf8-f8bf-3247-9b8e-\
6173a2b2723b"],

Cell["\<\
As mentioned above, due to calculational limits, computing the second order \
Shapiro time delay is computational intensive and with a symbolic manipulator \
like xAct it was taxing, but we can write the code out ourselves. The metric \
we used, that we check is indeed a solution, is here: \
https://arxiv.org/abs/2505.01878\
\>", "Text",
 CellChangeTimes->{{3.9847342865158367`*^9, 3.9847343554066505`*^9}, 
   3.984734391333128*^9},ExpressionUUID->"94469fe1-03b3-bc4d-bc37-\
c84fec67ebae"]
}, Closed]],

